# ─── Smart Mirror Environment Variables ───

GROQ_API_KEY=your_groq_api_key_here
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Weather
WEATHER_CITY=Kochi
WEATHER_COUNTRY_CODE=IN

# Vosk model path (download from https://alphacephei.com/vosk/models)
VOSK_MODEL_PATH=backend/models/vosk-model-small-en-us-0.15

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
